@page "/search"
@attribute [Authorize]
@using JobNexus.Core.Models
@using JobNexus.Core.Search
@using JobNexus.Services
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@inject SearchService SearchService

<PageTitle>Search Listings — JobNexus</PageTitle>

<div class="btn-toolbar mb-3" role="toolbar">

    <InputText @bind-Value="_keywordText"
               class="me-2"
               placeholder="Keywords&hellip;" />

    <div class="btn-group me-2" role="group">
        <InputSelect @bind-Value="_employmentLevel" class="btn btn-outline-secondary">
            <option value="">Employment Level</option>
            <option value="ft">Full-time</option>
            <option value="pt">Part-time</option>
            <option value="tmp">Temporary</option>
            <option value="int">Internship</option>
        </InputSelect>
    </div>

    <div class="input-group me-2" role="group">
        <span class="input-group-text" id="posted-after">
            <InputCheckbox @bind-Value="_usePostedAfter" /> Posted after
        </span>
        <InputDate class="input-group-text"
                   aria-describedby="posted-after"
                   @bind-Value="_postedAfter" />
    </div>

    <div class="btn-group me-2" role="group">
        <InputSelect @bind-Value="_selectedSource" class="btn btn-outline-secondary">
            <option value="">All Sources</option>
            <option value="Adzuna">Adzuna</option>
            <option value="JSearch">JSearch</option>
        </InputSelect>
    </div>

    <button type="button" class="btn btn-primary" @onclick="HandleSearch">Search</button>
    <button type="button" class="btn btn-outline-secondary ms-1" @onclick="ClearSearch">Clear</button>
</div>

@if (!string.IsNullOrEmpty(_infoMessage))
{
    <p class="text-muted">@_infoMessage</p>
}

@if (_jobListings is not null)
{
    <p class="text-muted mb-2">@_jobListings.Count result(s) found</p>
}

@if (_isLoading)
{
    <p><em>Loading...</em></p>
}

@if (_jobListings is not null && !_isLoading)
{
    <MudDataGrid Items="@_jobListings">
        <Columns>
            <PropertyColumn Property="x => x.Title" Title="Title" />

            <TemplateColumn Title="Company">
                <CellTemplate>
                    @(context.Item.Company?.CompanyName ?? "N/A")
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.Description" Title="Description" />

            <TemplateColumn Title="Pay">
                <CellTemplate>
                    @(context.Item.Pay.HasValue
                        ? context.Item.Pay.Value.ToString("C0")
                        : "N/A")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Date Posted">
                <CellTemplate>
                    @(context.Item.DatePosted.HasValue
                        ? context.Item.DatePosted.Value.ToString("MMM dd, yyyy")
                        : "N/A")
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Source">
                <CellTemplate>
                    <span class="badge @GetSourceBadgeClass(context.Item.Source?.SourceName)">
                        @(context.Item.Source?.SourceName ?? "Unknown")
                    </span>
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Apply">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.ApplyUrl))
                    {
                        <a href="@context.Item.ApplyUrl"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="btn btn-sm btn-success">
                            Apply
                        </a>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private string _keywordText = "";
    private string _employmentLevel = "";
    private bool _usePostedAfter = false;
    private DateTime _postedAfter = DateTime.Now;
    private string _selectedSource = "";
    private bool _isLoading = false;
    private string? _infoMessage;
    private List<Job>? _jobListings;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllJobs();
    }

    private async Task LoadAllJobs()
    {
        _isLoading = true;
        _infoMessage = null;
        _jobListings = await SearchService.SearchAsync(new SearchQuery
        {
            Keywords = [""]
        });
        _isLoading = false;
    }

    private async Task HandleSearch()
    {
        _isLoading = true;
        _infoMessage = null;

        var query = new SearchQuery
        {
            Keywords = string.IsNullOrWhiteSpace(_keywordText)
                ? [""]
                : _keywordText.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToList()
        };

        if (_usePostedAfter)
            query.DatePostedAfter = _postedAfter;

        var results = await SearchService.SearchAsync(query);

        if (!string.IsNullOrEmpty(_selectedSource))
            results = results
                .Where(j => j.Source?.SourceName == _selectedSource)
                .ToList();

        _jobListings = results;

        if (_jobListings.Count == 0)
            _infoMessage = "No results matched your search terms.";

        _isLoading = false;
    }

    private async Task ClearSearch()
    {
        _keywordText = "";
        _employmentLevel = "";
        _selectedSource = "";
        _usePostedAfter = false;
        _postedAfter = DateTime.Now;
        await LoadAllJobs();
    }

    private static string GetSourceBadgeClass(string? sourceName) => sourceName switch
    {
        "Adzuna" => "bg-primary",
        "JSearch" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}