<MudPaper Elevation="4" Style="background:#1e1e1e; border-radius:14px; border:1px solid #2a2a2a; height:100%;">

    <div style="padding:16px 20px; border-bottom:2px solid #ff6a00; display:flex; align-items:center; gap:10px;">
        <MudIcon Icon="@Icons.Material.Filled.Send" Style="color:#ff6a00;" />
        <MudText Style="color:#ff6a00; font-weight:600; font-size:0.95rem;">Applications</MudText>
    </div>

    <div style="padding:16px; display:flex; flex-direction:column; gap:10px;">

        <MudPaper Class="pa-3" Style="background:#2a2a2a; border-radius:10px; border:1px solid #333;">
            <MudText Style="color:white; font-weight:600; font-size:0.95rem;">Frontend Developer</MudText>
            <MudText Style="color:#aaa; font-size:0.8rem;" Class="mb-2">Google · Remote</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Open</MudChip>
        </MudPaper>

        <MudPaper Class="pa-3" Style="background:#2a2a2a; border-radius:10px; border:1px solid #333;">
            <MudText Style="color:white; font-weight:600; font-size:0.95rem;">UI Designer</MudText>
            <MudText Style="color:#aaa; font-size:0.8rem;" Class="mb-2">Meta · On-site</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Rejected</MudChip>
        </MudPaper>

        <MudPaper Class="pa-3" Style="background:#2a2a2a; border-radius:10px; border:1px solid #333;">
            <MudText Style="color:white; font-weight:600; font-size:0.95rem;">Systems Analyst</MudText>
            <MudText Style="color:#aaa; font-size:0.8rem;" Class="mb-2">IBM · Hybrid</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Pending</MudChip>
        </MudPaper>

    </div>

</MudPaper>
        
