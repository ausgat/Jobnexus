@using JobNexus.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<JobNexusContext> DbFactory

<MudPaper Elevation="8" Class="pa-8"
          Style="background:#1e1e1e; border-radius:16px; width:100%; max-width:420px; border:1px solid #2a2a2a;">

    <!-- Branding -->
    <div class="d-flex align-center justify-center mb-2">
        <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium"
                 Style="color:#ff6a00; font-size:2rem;" Class="me-2" />
        <MudText Typo="Typo.h5" Style="color:white; font-weight:700;">JobNexus</MudText>
    </div>
    <MudText Typo="Typo.body1" Class="text-center mb-6" Style="color:#888;">
        Sign in to your account
    </MudText>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
    }

    <MudForm OnValidSubmit="HandleLogin" FormName="login-form">
        <MudTextField T="string"
                      Label="Username"
                      Variant="Variant.Outlined"
                      Class="mb-1"
                      InputType="InputType.Text"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Person"
                      AdornmentColor="Color.Primary" />

        <MudTextField T="string"
                      Label="Password"
                      Variant="Variant.Outlined"
                      Class="mb-1 mt-3"
                      InputType="InputType.Password"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Lock"
                      AdornmentColor="Color.Primary" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Style="background:#ff6a00; color:white; font-weight:600; border-radius:8px; margin-top:16px;"
                   FullWidth="true"
                   Size="Size.Large">
            Sign In
        </MudButton>
    </MudForm>

    <MudDivider Class="my-5" Style="border-color:#333;" />

    <div class="d-flex justify-center align-center gap-1">
        <MudText Style="color:#888; font-size:0.9rem;">Don't have an account?</MudText>
        <MudLink Href="/profiles/create" Style="color:#ff6a00; font-weight:600; font-size:0.9rem;">
            Create one
        </MudLink>
    </div>

</MudPaper>

@code {
    private string? _errorMessage;

    private async Task HandleLogin()
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        // TODO: Add log in code here
        _errorMessage = "Invalid username or password.";
    }
}
