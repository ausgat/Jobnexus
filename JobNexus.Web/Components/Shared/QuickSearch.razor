@inject NavigationManager NavigationManager

<MudPaper Elevation="3"
          Class="pa-2 d-flex align-center"
          Style="width:min(700px, 100%); background:#1e1e1e; border-radius:40px; border:1px solid #333;">

    <MudTextField T="string"
                  @bind-Value="_homeSearch"
                  Placeholder="Quick search — press Enter or click Go"
                  Variant="Variant.Text"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  AdornmentColor="Color.Primary"
                  Class="flex-grow-1 ms-1"
                  Style="color:white;"
                  Immediate="true"
                  OnKeyDown="HandleSearchKeyDown" />

    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                   Style="background:#ff6a00; color:white; border-radius:50%; margin:4px;"
                   OnClick="GoToSearch" />
</MudPaper>

@code {
    private string _homeSearch = "";

    private void GoToSearch()
    {
        var query = Uri.EscapeDataString(_homeSearch.Trim());
        NavigationManager.NavigateTo(string.IsNullOrEmpty(query) ? "/search" : $"/search?q={query}");
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            GoToSearch();
    }
}
