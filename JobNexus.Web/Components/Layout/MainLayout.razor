@using JobNexus.Core.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inherits LayoutComponentBase
@inject UserManager<Profile> UserManager

<MudPopoverProvider />

<MudThemeProvider Theme="_darkTheme" IsDarkMode="true" />

<MudLayout>

    <!-- Top Bar -->
    <MudAppBar Elevation="2"
               Style="background-color:#1e1e1e; border-bottom:2px solid #ff6a00;">

        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />

        <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium"
                 Style="color:#ff6a00; font-size:1.6rem;" Class="ms-2 me-1" />

        <MudText Typo="Typo.h6" Style="color:white; font-weight:700; letter-spacing:0.5px;">
            JobNexus
        </MudText>

        <MudSpacer />

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_currentProfile is null)
        {
            <MudButton Href="/login"
                       Variant="Variant.Outlined"
                       Style="border-color:#ff6a00; color:#ff6a00; font-weight:600;"
                       Size="Size.Small">
                Sign In
            </MudButton>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Person" />
            <MudLink Href="/me">@_currentProfile.Name</MudLink>
            <MudButton Href="/logout"
                       Variant="Variant.Outlined"
                       Style="border-color:#ff6a00; color:#ff6a00; font-weight:600;"
                       Size="Size.Small">
                Sign Out
            </MudButton>
        }
        </MudStack>
        
    </MudAppBar>

    <!-- Sidebar -->
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Elevation="2"
               Style="background-color:#1e1e1e;">

        <div style="padding:20px 16px 8px 16px;">
            <MudText Style="color:#666; font-size:0.68rem; font-weight:600; letter-spacing:1.8px;">NAVIGATION</MudText>
        </div>

        <NavMenu />

    </MudDrawer>

    <!-- Main Content -->
    <MudMainContent Style="background-color:#121212; min-height:100vh;">
        <div class="main-content-inner">
            @Body
        </div>
    </MudMainContent>

</MudLayout>

<style>
    .main-content-inner {
        padding: 24px;
    }

    .nav-item-custom {
        color: #e0e0e0 !important;
        border-radius: 8px;
        margin-bottom: 4px;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .nav-item-custom:hover {
        background-color: #2a2a2a !important;
        color: white !important;
    }

    .nav-item-custom.active {
        background-color: #ff6a00 !important;
        color: white !important;
    }

    .nav-item-custom.active .mud-icon-root {
        color: white !important;
    }
</style>

@code {
    
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private Profile? _currentProfile;

    private bool _drawerOpen = true;
    
    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationState is not null)
        {
            var authState = await AuthenticationState;
            var user = authState?.User;

            if (user?.Identity is not null && user.Identity.IsAuthenticated)
            {
                _currentProfile = await UserManager.GetUserAsync(user);
            }
            
            Console.WriteLine($"Hello, {_currentProfile?.Name}");
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private MudTheme _darkTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Background = "#121212",
            Surface = "#1e1e1e",
            Primary = "#ff6a00",
            Secondary = "#ff8c40",
            AppbarBackground = "#1e1e1e",
            DrawerBackground = "#1e1e1e",
            TextPrimary = "#ffffff",
            TextSecondary = "#cccccc",
            ActionDefault = "#aaaaaa"
        }
    };
}
