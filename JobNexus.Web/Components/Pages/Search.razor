@page "/search"
@using JobNexus.Core.Models
@using JobNexus.Core.Search
@using JobNexus.Services
@using MudBlazor
@rendermode InteractiveServer
@inject SearchService SearchService

<PageTitle>Search Jobs — JobNexus</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0">

    <div class="mb-6">
        <MudText Typo="Typo.h4" Style="color:white; font-weight:700;">Search Jobs</MudText>
        <MudText Style="color:#999; margin-top:4px;">Find your next opportunity</MudText>
    </div>

    <MudPaper Elevation="4" Class="pa-5 mb-6"
              Style="background:#1e1e1e; border-radius:14px; border:1px solid #2a2a2a;">

        <MudGrid Spacing="3">

            <MudItem xs="12" md="5">
                <MudTextField T="string"
                              Label="Keywords"
                              Placeholder="Job title, skills, company..."
                              Variant="Variant.Outlined"
                              @bind-Value="_keywordText"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              AdornmentColor="Color.Primary" />
            </MudItem>

            <MudItem xs="12" md="5">
                <MudText Style="color:#aaa; font-size:0.8rem; font-weight:600; letter-spacing:0.5px;" Class="mb-2">EMPLOYMENT TYPE</MudText>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var type in _employmentTypes)
                    {
                        <MudChip T="string"
                                 Text="@type"
                                 Variant="@(_employmentLevel == type ? Variant.Filled : Variant.Outlined)"
                                 Color="@(_employmentLevel == type ? Color.Primary : Color.Default)"
                                 OnClick="@(() => SetEmployment(type))"
                                 Style="cursor:pointer; font-weight:500;" />
                    }
                </div>
            </MudItem>

            <MudItem xs="12" md="2" Class="d-flex flex-column justify-end">
                <div class="d-flex align-center mb-2">
                    <MudCheckBox @bind-Value="_usePostedAfter" Label="Posted after" Color="Color.Primary" />
                </div>
                @if (_usePostedAfter)
                {
                    <MudDatePicker @bind-Date="_postedAfter"
                                   Variant="Variant.Outlined"
                                   Class="mb-2" />
                }
                <MudButton Variant="Variant.Filled"
                           Style="background:#ff6a00; color:white; font-weight:600; border-radius:8px;"
                           FullWidth="true"
                           OnClick="HandleSearch">
                    Search
                </MudButton>
            </MudItem>

        </MudGrid>

    </MudPaper>

    @if (_isLoading)
    {
        <div class="d-flex justify-center pa-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_jobListings == null)
    {
        <div class="d-flex flex-column align-center justify-center" style="padding:60px 0;">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="color:#444; font-size:4rem;" Class="mb-3" />
            <MudText Typo="Typo.h6" Style="color:#666;">Enter keywords and hit Search to find jobs</MudText>
        </div>
    }
    else if (_jobListings.Count == 0)
    {
        <div class="d-flex flex-column align-center justify-center" style="padding:60px 0;">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="color:#444; font-size:4rem;" Class="mb-3" />
            <MudText Typo="Typo.h6" Style="color:#666;">No jobs found — try different keywords</MudText>
        </div>
    }
    else
    {
        <MudText Style="color:#888; font-size:0.85rem;" Class="mb-3">@_jobListings.Count result(s) found</MudText>
        <MudGrid Spacing="3">

            @foreach (var job in _jobListings)
            {
                <MudItem xs="12" md="6" lg="4">

                    <MudPaper Elevation="6" Class="pa-5"
                              Style="background:#1e1e1e; border-radius:14px; border:1px solid #2a2a2a; height:100%;">

                        <div class="d-flex justify-space-between align-start mb-3">
                            <MudText Typo="Typo.h6" Style="color:#ff6a00; font-weight:700; line-height:1.3;">
                                @job.Title
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Dark" Style="background:#2a2a2a; color:#ccc;">
                                @(job.Source?.SourceName ?? "Unknown")
                            </MudChip>
                        </div>

                        @if (!string.IsNullOrEmpty(job.Company?.CompanyName))
                        {
                            <MudText Style="color:#aaa; font-size:0.85rem; font-weight:600;" Class="mb-2">
                                @job.Company.CompanyName
                            </MudText>
                        }

                        <MudText Style="color:#bbb; font-size:0.9rem; line-height:1.5;" Class="mb-3">
                            @(job.Description?.Length > 150
                                ? job.Description[..150] + "..."
                                : job.Description ?? "No description available.")
                        </MudText>

                        <div class="d-flex align-center gap-3 mb-4">
                            @if (job.Pay.HasValue)
                            {
                                <div class="d-flex align-center gap-1">
                                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color:#ff6a00; font-size:1rem;" />
                                    <MudText Style="color:#ccc; font-size:0.85rem;">@job.Pay.Value.ToString("C0")/yr</MudText>
                                </div>
                            }
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="color:#888; font-size:0.9rem;" />
                                <MudText Style="color:#888; font-size:0.85rem;">@(job.DatePosted?.ToString("MMM d, yyyy") ?? "Unknown")</MudText>
                            </div>
                        </div>

                        <MudDivider Style="border-color:#2a2a2a;" Class="mb-3" />

                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.BookmarkBorder"
                                       OnClick="@(() => AddToInterested(job))">
                                Save
                            </MudButton>
                            @if (!string.IsNullOrEmpty(job.ApplyUrl))
                            {
                                <MudButton Variant="Variant.Filled"
                                           Style="background:#ff6a00; color:white; font-weight:600;"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Send"
                                           Href="@job.ApplyUrl"
                                           Target="_blank">
                                    Apply
                                </MudButton>
                            }
                        </div>

                    </MudPaper>

                </MudItem>
            }

        </MudGrid>
    }

</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "q")]
    private string? QueryKeyword { get; set; }

    private string _keywordText = "";
    private string _employmentLevel = "";
    private bool _usePostedAfter = false;
    private DateTime? _postedAfter = DateTime.Now;
    private bool _isLoading = false;

    private readonly List<string> _employmentTypes = new() { "Full-time", "Part-time", "Temporary", "Internship" };

    private List<Job>? _jobListings;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(QueryKeyword))
        {
            _keywordText = QueryKeyword;
            await HandleSearch();
        }
    }

    private async Task HandleSearch()
    {
        _isLoading = true;

        var query = new SearchQuery
        {
            Keywords = string.IsNullOrWhiteSpace(_keywordText)
                ? [""]
                : _keywordText.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToList()
        };

        if (_usePostedAfter && _postedAfter.HasValue)
            query.DatePostedAfter = _postedAfter.Value;

        _jobListings = await SearchService.SearchAsync(query);
        _isLoading = false;
    }

    private void SetEmployment(string type)
    {
        _employmentLevel = _employmentLevel == type ? "" : type;
    }

    private void AddToInterested(Job job)
    {
        // TODO: Wire to user saved jobs once auth is implemented
        Console.WriteLine($"Saved: {job.Title}");
    }
}