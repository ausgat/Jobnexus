@page "/profiles/delete"
@using Microsoft.EntityFrameworkCore
@using JobNexus.Core.Models
@inject IDbContextFactory<JobNexus.Data.JobNexusContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Profile — JobNexus</PageTitle>

@if (profile is null)
{
    <div class="d-flex justify-center align-center" style="min-height:60vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else
{
    <div class="d-flex justify-center" style="min-height:80vh; align-items:flex-start; padding-top:24px;">
        <MudPaper Elevation="6" Class="pa-8"
                  Style="background:#1e1e1e; border-radius:16px; width:100%; max-width:480px; border:2px solid #b91c1c;">

            <div class="d-flex align-center mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color:#ef4444; font-size:1.8rem;" Class="me-2" />
                <MudText Typo="Typo.h5" Style="color:white; font-weight:700;">Delete Profile</MudText>
            </div>
            <MudText Style="color:#aaa; font-size:0.95rem;" Class="mb-6">
                This action cannot be undone. Please confirm the details below.
            </MudText>

            <MudPaper Class="pa-4 mb-6" Style="background:#2a2a2a; border-radius:10px; border:1px solid #333;">
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-space-between">
                        <MudText Style="color:#888; font-size:0.85rem;">Username</MudText>
                        <MudText Style="color:white; font-weight:600;">@profile.Username</MudText>
                    </div>
                    <MudDivider Style="border-color:#333;" />
                    <div class="d-flex justify-space-between">
                        <MudText Style="color:#888; font-size:0.85rem;">Email</MudText>
                        <MudText Style="color:#ccc;">@(profile.Email ?? "—")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Style="color:#888; font-size:0.85rem;">Name</MudText>
                        <MudText Style="color:#ccc;">@(profile.Name ?? "—")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Style="color:#888; font-size:0.85rem;">Location</MudText>
                        <MudText Style="color:#ccc;">@(profile.Location ?? "—")</MudText>
                    </div>
                </div>
            </MudPaper>

            <EditForm method="post" Model="profile" OnValidSubmit="DeleteProfile" FormName="delete" Enhance>
                <div class="d-flex gap-3">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Style="background:#ef4444; color:white; font-weight:600; border-radius:8px;"
                               StartIcon="@Icons.Material.Filled.Delete"
                               FullWidth="true" Size="Size.Large"
                               Disabled="@(profile is null)">
                        Delete Profile
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Href="/profiles"
                               Size="Size.Large"
                               FullWidth="true">
                        Cancel
                    </MudButton>
                </div>
            </EditForm>

        </MudPaper>
    </div>
}

@code {
    private Profile? profile;

    [SupplyParameterFromQuery]
    private string Username { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        profile = await context.Profiles.FirstOrDefaultAsync(m => m.Username == Username);

        if (profile is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteProfile()
    {
        using var context = DbFactory.CreateDbContext();
        context.Profiles.Remove(profile!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/profiles");
    }
}
