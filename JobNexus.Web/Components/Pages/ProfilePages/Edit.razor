@page "/profiles/edit"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using JobNexus.Core.Models
@using JobNexus.Web.ViewModels
@using Microsoft.AspNetCore.Authorization

@inject IDbContextFactory<Data.JobNexusContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Profile — JobNexus</PageTitle>

@if (Profile is null)
{
    <div class="d-flex justify-center align-center" style="min-height:60vh;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else
{
    <div class="d-flex justify-center" style="min-height:80vh; align-items:flex-start; padding-top:24px;">
        <MudPaper Elevation="6" Class="pa-8"
                  Style="background:#1e1e1e; border-radius:16px; width:100%; max-width:500px; border:1px solid #2a2a2a;">

            <div class="d-flex align-center mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Style="color:#ff6a00; font-size:1.6rem;" Class="me-2" />
                <MudText Typo="Typo.h5" Style="color:white; font-weight:700;">Edit Profile</MudText>
            </div>
            <MudText Style="color:#888; font-size:0.9rem;" Class="mb-6">
                Editing: <strong style="color:#ff6a00;">@Profile.UserName</strong>
            </MudText>

            <EditForm method="post" Model="ProfileForm" OnValidSubmit="UpdateProfile" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" class="validation-message mb-3" />
                <InputHidden id="username" @bind-Value="ProfileForm!.Username" />

                <MudTextField T="string" Label="Email" @bind-Value="ProfileForm!.Email"
                              Variant="Variant.Outlined" Class="mb-3"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                              AdornmentColor="Color.Primary" />
                <ValidationMessage For="() => ProfileForm!.Email" class="validation-message mb-2" />

                <MudTextField T="string" Label="Full Name" @bind-Value="ProfileForm!.Name"
                              Variant="Variant.Outlined" Class="mb-3"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                              AdornmentColor="Color.Primary" />

                <MudTextField T="string" Label="Bio" @bind-Value="ProfileForm!.Bio"
                              Variant="Variant.Outlined" Class="mb-3"
                              Lines="3" />

                <MudTextField T="string" Label="Location" @bind-Value="ProfileForm!.Location"
                              Variant="Variant.Outlined" Class="mb-5"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocationOn"
                              AdornmentColor="Color.Primary" />

                <div class="d-flex gap-3">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Style="background:#ff6a00; color:white; font-weight:600; border-radius:8px;"
                               FullWidth="true" Size="Size.Large">
                        Save Changes
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               Href="@($"/profiles/details?username={Profile!.UserName}")"
                               Size="Size.Large">
                        Cancel
                    </MudButton>
                </div>
            </EditForm>

        </MudPaper>
    </div>
}

@code {
[CascadingParameter]
private Task<AuthenticationState>? AuthenticationState { get; set; }

[SupplyParameterFromForm]
private ProfileModel? ProfileForm { get; set; }

private Profile? Profile { get; set; }

protected override async Task OnInitializedAsync()
{
    if (AuthenticationState != null)
    {
        var authState = await AuthenticationState;
        var user = authState?.User;

        if (user?.Identity is not null && user.Identity.IsAuthenticated)
        {
            await using var context = await DbFactory.CreateDbContextAsync();
            Profile ??= await context.Profiles.FirstOrDefaultAsync(
                m => m.UserName == user.Identity.Name);

            if (Profile is not null && Profile.UserName is not null)
            {
                ProfileForm ??= new ProfileModel
                {
                    Username = Profile.UserName,
                    Email = Profile.Email,
                    Name = Profile.Name,
                    Bio = Profile.Bio,
                    Location = Profile.Location
                };
                return;
            }
        }
    }

    NavigationManager.NavigateTo("notfound");
}
    private async Task UpdateProfile()
    {
        if (AuthenticationState != null){
            var authState = await AuthenticationState;
            var user = authState?.User;
            if (user?.Identity?.Name != Profile!.UserName)
            {
                NavigationManager.NavigateTo("notfound");
                return;
            }
        }

        await using var context = await DbFactory.CreateDbContextAsync();
        context.Attach(Profile!).State = EntityState.Modified;

        if (Profile is not null && ProfileForm is not null)
        {
            Profile.Email = ProfileForm.Email;
            Profile.Name = ProfileForm.Name;
            Profile.Bio = ProfileForm.Bio;
            Profile.Location = ProfileForm.Location;
        }

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            var userName = Profile!.UserName;
            if (userName != null && !ProfileExists(userName))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/profiles");
    }

    private bool ProfileExists(string username)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Profiles.Any(e => e.UserName == username);
    }
}
