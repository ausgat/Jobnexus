@page "/profiles/edit"
@using Microsoft.EntityFrameworkCore
@using JobNexus.Core.Models
@inject IDbContextFactory<Data.JobNexusContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Profile</h2>
<hr />
@if (Profile is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="ProfileForm" OnValidSubmit="UpdateProfile" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <InputHidden id="username" @bind-Value="ProfileForm.Username" />
                <div class="mb-3">
                    <label for="password" class="form-label">Password:</label>
                    <InputText id="password" @bind-Value="ProfileForm.Password" class="form-control" />
                    <ValidationMessage For="() => ProfileForm.Password" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email:</label>
                    <InputText id="email" @bind-Value="ProfileForm.Email" class="form-control" />
                    <ValidationMessage For="() => ProfileForm.Email" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="name" class="form-label">Name:</label>
                    <InputText id="name" @bind-Value="ProfileForm.Name" class="form-control" />
                    <ValidationMessage For="() => ProfileForm.Name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="bio" class="form-label">Bio:</label>
                    <InputText id="bio" @bind-Value="ProfileForm.Bio" class="form-control" />
                    <ValidationMessage For="() => ProfileForm.Bio" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location:</label>
                    <InputText id="location" @bind-Value="ProfileForm.Location" class="form-control" />
                    <ValidationMessage For="() => ProfileForm.Location" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/profiles">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? Username { get; set; }

    [SupplyParameterFromForm]
    private ProfileForm? ProfileForm { get; set; }

    private Profile? Profile { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        Profile ??= await context.Profiles.FirstOrDefaultAsync(m => m.Username == Username);

        if (Profile is not null)
        {
            ProfileForm ??= new ProfileForm
            {
                Username = Profile.Username,
                Password = Profile.Password,
                Email = Profile.Email,
                Name = Profile.Name,
                Bio = Profile.Bio,
                Location = Profile.Location
            };
        }
        else
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateProfile()
    {
        await using var context = await DbFactory.CreateDbContextAsync();
        context.Attach(Profile!).State = EntityState.Modified;

        if (Profile is not null && ProfileForm is not null)
        {
            Profile.Password = ProfileForm.Password;
            Profile.Email = ProfileForm.Email;
            Profile.Name = ProfileForm.Name;
            Profile.Bio = ProfileForm.Bio;
            Profile.Location = ProfileForm.Location;
        }

        try
        {
            await context.SaveChangesAsync();               
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!ProfileExists(Profile!.Username))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/profiles");
    }

    private bool ProfileExists(string username)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Profiles.Any(e => e.Username == username);
    }
}
